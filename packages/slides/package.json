{
	"name": "@hoverkraft/slidev-theme-slides",
	"private": true,
	"version": "0.0.0",
	"description": "Example Slidev deck for the Hoverkraft Slidev theme.",
	"type": "module",
	"engines": {
		"node": ">=20.12.0"
	},
	"scripts": {
