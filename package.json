{
	"name": "@hoverkraft/slidev-theme-workspace",
	"private": true,
	"version": "0.0.0",
	"description": "Workspace for the Hoverkraft Slidev theme and example deck.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/hoverkraft-tech/slidev-theme.git"
	},
	"engines": {
		"node": ">=20.12.0"
	},
	"workspaces": [
		"packages/theme",
		"packages/slides"
	],
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"start": "npm run start --workspace=@hoverkraft/slidev-theme-slides",
		"lint": "npm run lint --workspaces --if-present",
		"lint:fix": "npm run lint:fix --workspaces --if-present",
		"lint:ci": "npm run lint:ci --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"test:ci": "npm run test:ci --workspaces --if-present",
		"pack": "npm pack --workspace=@hoverkraft/slidev-theme"
	}
}
